PORT=5000
MONGODB_URI=mongodb://localhost:27017/securevault
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AES_ENCRYPTION_KEY=your_32_char_aes_key_here_secure
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
OTP_EXPIRY_MINUTES=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@securevault.com
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
